// A launch configuration that compiles the extension and then opens it inside a new window
{
    "version": "0.1.0",
    "configurations": [
        {
            "name": "Launch Extension",
            "type": "extensionHost",
            "request": "launch",
            "runtimeExecutable": "${execPath}",
            "args": ["--extensionDevelopmentPath=${workspaceRoot}/vscode-lean4"],
            "stopOnEntry": false,
            "sourceMaps": true,
            "outFiles": ["${workspaceRoot}/*/dist/**/*.js"],
            "preLaunchTask": "watch",
            "debugWebviews": true,
            "rendererDebugOptions": {
                "webRoot": "${workspaceRoot}/vscode-lean4/media"
            }
        },
        {
            // Debug a single vscode-test-cli label inside the Extension
            // Development Host. Breakpoints work in both the test file and
            // anything under `vscode-lean4/src/`. The label list mirrors
            // the files under `vscode-lean4/test/vscode-test-cli/` —
            // update the `inputs` block below if a new test file is added.
            "name": "Debug vscode-test-cli (pick label)",
            "type": "extensionHost",
            "request": "launch",
            "testConfiguration": "${workspaceFolder}/vscode-lean4/.vscode-test.mjs",
            "testConfigurationLabel": "cli-${input:cliLabel}",
            "outFiles": ["${workspaceFolder}/vscode-lean4/out/**/*.js"],
            "preLaunchTask": "compile-tests"
        },
        {
            // Debug the currently-open vitest test file. Vitest spawns
            // workers by default; `autoAttachChildProcesses` follows them
            // so breakpoints land. Pure-TS path (no VS Code, no xvfb).
            "name": "Debug Vitest (current file)",
            "type": "node",
            "request": "launch",
            "program": "${workspaceFolder}/node_modules/vitest/vitest.mjs",
            "args": ["run", "${relativeFile}"],
            "autoAttachChildProcesses": true,
            "smartStep": true,
            "console": "integratedTerminal",
            "skipFiles": ["<node_internals>/**", "**/node_modules/**"]
        },
        {
            // Run the full non-network suite (vitest + infoview tsc +
            // grammar + vscode-test-cli + wdio) without a debugger.
            // Opens real VS Code windows for the integration steps,
            // which grab focus for the duration. `preLaunchTask: build`
            // populates workspace dist/ so the infoview tsc step's
            // cross-package imports resolve.
            "name": "Run all non-network tests",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "npm",
            "runtimeArgs": ["test"],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "preLaunchTask": "build",
            "skipFiles": ["<node_internals>/**"]
        },
        {
            // Same as above, wrapped via `vscode-lean4/scripts/headless.mjs`.
            // On Linux that script wraps the inner command in `xvfb-run -a`
            // so the integration steps render to a virtual X display and
            // don't steal focus from your DE — requires
            // `xorg-x11-server-Xvfb` (Fedora) or `xvfb` (Debian/Ubuntu).
            // On Windows / macOS it runs the inner command directly.
            "name": "Run all non-network tests (headless)",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "npm",
            "runtimeArgs": ["run", "test:headless"],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "preLaunchTask": "build",
            "skipFiles": ["<node_internals>/**"]
        },
        {
            // Run the full network suite — exercises the real elan
            // install flow plus `lake new … math` (Mathlib clone +
            // cache fetch). Slow (tens of minutes) and network-heavy.
            // `setupTestHome` silently tolerates a missing elan binary
            // on PATH; the elan-install test installs it itself as part
            // of what it covers.
            "name": "Run all network tests",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "npm",
            "runtimeArgs": ["run", "test:network", "--workspace=lean4"],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "preLaunchTask": "build",
            "skipFiles": ["<node_internals>/**"]
        },
        {
            // Same as above, xvfb-wrapped via `test:headless:network`.
            "name": "Run all network tests (headless)",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "npm",
            "runtimeArgs": ["run", "test:headless:network", "--workspace=lean4"],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "preLaunchTask": "build",
            "skipFiles": ["<node_internals>/**"]
        }
    ],
    "inputs": [
        {
            "id": "cliLabel",
            "type": "pickString",
            "description": "vscode-test-cli label to debug",
            "options": [
                "abbreviation",
                "lakefile-toml-schema",
                "launch-modes",
                "preconditions",
                "project-actions",
                "project-init",
                "server-launch",
                "smoke",
                "version-management"
            ]
        }
    ]
}
